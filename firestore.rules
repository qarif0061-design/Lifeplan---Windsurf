rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwnerByField() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function isOwnerExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if signedIn() && request.auth.uid == userId;
      allow create: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    match /goals/{goalId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwnerByField();
      allow update: if isOwnerExisting();
      allow delete: if isOwnerExisting();
    }

    match /checkins/{checkinId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwnerByField();
      allow update: if isOwnerExisting();
      allow delete: if isOwnerExisting();
    }

    match /plans/{planId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwnerByField();
      allow update: if isOwnerExisting();
      allow delete: if isOwnerExisting();
    }

    match /daily_tasks/{dayId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if isOwnerByField();
      allow update: if isOwnerExisting();
      allow delete: if isOwnerExisting();
    }
  }
}
